<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>PinkyBean</title>

		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
		<link rel="stylesheet" href="/css/styles.css" />
	</head>

	<body>
		<div class="container-main">
			<div
				class="topbar"
				style="display: flex; justify-content: space-between; align-items: center">
				<div style="font-size: 30px;">💖 PinkyyBeanyMall 💖</div>

				<button id="music-toggle" class="music-btn">▶</button>
			</div>

			<audio id="bg-music" loop>
				<source src="/music/Delulu.mp3" type="audio/mpeg" />
			</audio>

			<div class="navbar-2000 mt-2">
				<a href="#">HOME</a>
				<a href="#">SHOP</a>
				<a href="#">STYLE</a>
				<a href="#">SALE</a>
				<a href="#">PROFILE</a>
			</div>

			<div class="layout mt-2">
				<!-- LEFT SIDEBAR -->
				<div class="sidebar">
					<div class="box">
						<div class="box-header">My Account</div>
						<div style="padding: 5px">
							💰 Coins: 9999 <br />
							👤 User: Admin
						</div>
					</div>

					<div class="box">
						<div class="box-header">Menu</div>
						<div style="padding: 5px">
							🛍 My Shop <br />
							⭐ Favorites <br />
							📝 Orders
						</div>
					</div>
				</div>

				<!-- MAIN CONTENT -->
				<div class="main"></div>
			</div>
		</div>
	</body>
</html>
