  <img id="modalOverlay" src="/images/download.gif" alt="Modal Overlay">

  <!-- Modal Form -->
  <div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <form id="product-form">
          <div class="modal-header">
            <h5 class="modal-title" id="modalTitle">Add Product</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <input type="hidden" id="product-id">
            <div class="mb-3">
              <label class="form-label">Name</label>
              <input id="name" name="name" type="text" class="form-control" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Price</label>
              <input id="price" name="price" type="number" step="0.01" class="form-control" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Color</label>
              <input id="color" name="color" type="text" class="form-control" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Description</label>
              <textarea id="description" name="description" class="form-control" rows="2"></textarea>
            </div>
            <div class="mb-3">
              <label class="form-label">Image</label>
              <input id="imageFile" name="imageFile" type="file" accept="image/*" class="form-control">
              <input type="hidden" id="imageUrl" name="imageUrl">
              <div class="mt-2">
                <img id="img-preview" src="/images/placeholder-80.png" alt="preview" class="img-thumbnail" style="width:250px;height:250px;object-fit:cover">
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary custom-modal-btn" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary custom-modal-btn">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>

<div class="box">
  <div class="box-header">🍎 Apple Products</div>

  <div style="padding:10px; display:flex; flex-wrap:wrap; gap:15px">

    <% products.forEach(function(p){ %>
    <div class="product-item" data-id="<%= p.id %>" data-image="<%= p.imageUrl || '' %>" style="flex: 0 0 300px; border:1px solid #ff99cc; padding:5px; text-align:center">
    
      <img 
        src="<%= p.imageUrl && p.imageUrl.length ? p.imageUrl : '/images/placeholder-80.png' %>" 
        style="width:280px;height:280px;object-fit:cover">

      <div class="product-name"><%= p.name %></div>
      <div class="product-price">$<%= p.price %></div>
      <div class="product-description" style="font-size:19px; color:#5c5ca4">
        <%= p.description || '' %>
      </div>
      <div class="product-color" style="display:none;"><%= p.color %></div>

      <div style="margin-top:5px">
        <button class="btn-edit">Edit</button>
        <button class="btn-delete">Delete</button>
      </div>

    </div>
    <% }) %>

  </div>
</div>

  <!-- Left Sidebar -->
   <div class="box">
