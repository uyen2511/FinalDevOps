[managers]
manager-1 ansible_host=YOUR_MANAGER_IP ansible_user=ubuntu

[workers]
worker-1 ansible_host=YOUR_WORKER_1_IP ansible_user=ubuntu
worker-2 ansible_host=YOUR_WORKER_2_IP ansible_user=ubuntu

[swarm:children]
managers
workers

[all:vars]
ansible_ssh_private_key_file=~/.ssh/your-key.pem
swarm_manager_ip=YOUR_MANAGER_INTERNAL_IP
